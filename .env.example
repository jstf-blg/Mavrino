# ─────────────────────────────────────────────
#  Affiliate Pipeline — Environment Config
#  Copy this to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Amazon Product Advertising API
# Get from affiliate-program.amazon.com → Tools → Product Advertising API
AMAZON_ACCESS_KEY=your_amazon_pa_api_access_key
AMAZON_SECRET_KEY=your_amazon_pa_api_secret_key
AMAZON_ASSOCIATE_TAG=yourtag-20

# SerpApi (serpapi.com) — for Google Trends keyword discovery
# Free tier: 100 searches/month. Paid from $75/month.
SERPAPI_KEY=your_serpapi_key_here

# Apify (apify.com) — for Amazon bestseller scraping
# Free tier available. Pay-per-use after that.
APIFY_TOKEN=your_apify_token_here

# Site config
SITE_DOMAIN=https://yourdomain.com
SITE_NAME=Your Site Name
AUTHOR_NAME=Your Name
AUTHOR_BIO=Consumer product researcher with 5+ years testing kitchen and home appliances.

# Publishing config
POSTS_PER_DAY=5
# Ramp schedule: start at 5, move to 20 after 30 days, 50 after 60, 200 after 90
# Change this number as you build domain history

# Niche categories (comma-separated, used for trend discovery)
NICHES=air fryers,coffee makers,blenders,food processors,stand mixers,toaster ovens,electric kettles,juicers

# Output directory (where HTML files go before git push)
OUTPUT_DIR=./output
